{
  "id": "codex-openai-fallback",
  "name": "Codex/OpenAI Fallback",
  "description": "Rate-limit circuit breaker that falls back from openai-codex to openai API and auto-recovers.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "cooldownSeconds": { "type": "integer", "minimum": 15, "maximum": 3600 },
      "primaryProvider": { "type": "string" },
      "primaryModelPrefixes": {
        "type": "array",
        "items": { "type": "string" }
      },
      "fallbackProvider": { "type": "string" },
      "fallbackModel": { "type": "string" }
    }
  }
}
