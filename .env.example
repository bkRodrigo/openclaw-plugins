# OpenClaw plugin local defaults (used by scripts/* when .env exists)
# Copy this file to .env and adjust per environment.

# Base Linux user that owns host-level OpenClaw paths.
PLUGIN_HOST_USER=your-linux-user
PLUGIN_HOME=/home/${PLUGIN_HOST_USER}

# Optional override if openclaw is not on PATH.
OPENCLAW_BIN=${PLUGIN_HOME}/.npm-global/bin/openclaw

# Runtime identity and env (used mainly by test script).
RUNTIME_USER=openclaw
RUNTIME_HOME=/home/${RUNTIME_USER}
RUNTIME_PATH=${PLUGIN_HOME}/.nvm/current/bin:${PLUGIN_HOME}/.npm-global/bin:/usr/local/bin:/usr/bin:/bin

# OpenClaw runtime paths.
OPENCLAW_STATE_DIR=${PLUGIN_HOME}/.openclaw
OPENCLAW_CONFIG_PATH=${OPENCLAW_STATE_DIR}/openclaw.json
OPENCLAW_WORKSPACE=${OPENCLAW_STATE_DIR}/workspace

# Deploy script settings.
OPENCLAW_ROOT=${PLUGIN_HOME}/.npm-global/lib/node_modules/openclaw
OPENCLAW_CONFIG=${OPENCLAW_CONFIG_PATH}

# Deterministic fallback test defaults.
ARM_SECONDS=120
COMMAND_TIMEOUT_SECONDS=120
EXPECTED_FALLBACK=openai/gpt-5.3-codex
EXPECTED_PRIMARY=openai-codex/gpt-5.3-codex
