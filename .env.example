# OpenClaw plugin local defaults (used by scripts/* when .env exists)
# Copy this file to .env and adjust per environment.

# Optional override if openclaw is not on PATH.
OPENCLAW_BIN=/home/forge/.npm-global/bin/openclaw

# Runtime identity and env (used mainly by test script).
RUNTIME_USER=openclaw
RUNTIME_HOME=/home/openclaw
RUNTIME_PATH=/home/forge/.nvm/current/bin:/home/forge/.npm-global/bin:/usr/local/bin:/usr/bin:/bin

# OpenClaw runtime paths.
OPENCLAW_STATE_DIR=/home/forge/.openclaw
OPENCLAW_CONFIG_PATH=/home/forge/.openclaw/openclaw.json
OPENCLAW_WORKSPACE=/home/forge/.openclaw/workspace

# Deploy script settings.
OPENCLAW_ROOT=/home/forge/.npm-global/lib/node_modules/openclaw
OPENCLAW_CONFIG=/home/forge/.openclaw/openclaw.json

# Deterministic fallback test defaults.
ARM_SECONDS=120
COMMAND_TIMEOUT_SECONDS=120
EXPECTED_FALLBACK=openai/gpt-5.3-codex
EXPECTED_PRIMARY=openai-codex/gpt-5.3-codex
